<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>GameHub</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>com.gamehub.ios</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UIStatusBarHidden</key>
    <true/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
        <string>metal</string>
    </array>
    <key>UISupportedExternalAccesoryProtocols</key>
    <array/>
    <key>NSCameraUsageDescription</key>
    <string>GameHub needs camera access for QR code scanning.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>GameHub needs microphone access for in-game voice chat.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>GameHub needs photo library access for screenshots and game captures.</string>
    <key>NSDocumentsFolderUsageDescription</key>
    <string>GameHub needs access to documents to manage game files.</string>
    <key>NSNetworkNotificationsUsageDescription</key>
    <string>GameHub needs network access for game updates and online features.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>GameHub uses local network for multiplayer and file sharing.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_gamehub._tcp</string>
        <string>_gamehub._udp</string>
    </array>
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>NSHighResolutionUsageDescription</key>
    <string>GameHub uses high-resolution display for game rendering.</string>
    <key>UIAppFonts</key>
    <array>
        <string>Menlo</string>
        <string>Courier</string>
    </array>
    <key>UIScreenOverscanExternalDisplayUsageInfo</key>
    <dict>
        <key>UIAspectRatio</key>
        <string>16:9</string>
        <key>UIAspectRatioPreserved</key>
        <true/>
    </dict>
    <key>UIExternalAccessoryProtocols</key>
    <array/>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>GameHub uses Bluetooth for controller support.</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>GameHub uses Bluetooth for controller support.</string>
    <key>NSHealthShareUsageDescription</key>
    <string>GameHub does not access health data.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>GameHub does not access health data.</string>
    <key>NSMotionUsageDescription</key>
    <string>GameHub uses motion data for controller gyroscope support.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>GameHub does not access location data.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>GameHub does not access location data.</string>
    <key>NSCalendarsUsageDescription</key>
    <string>GameHub does not access calendar data.</string>
    <key>NSContactsUsageDescription</key>
    <string>GameHub does not access contacts.</string>
    <key>NSRemindersUsageDescription</key>
    <string>GameHub does not access reminders.</string>
    <key>NSAppleMusicUsageDescription</key>
    <string>GameHub does not access Apple Music.</string>
    <key>NSFaceIDUsageDescription</key>
    <string>GameHub uses Face ID for app authentication.</string>
</dict>
</plist>
